{
  "name": "perforation-stabilizer",
  "version": "2.3.8",
  "description": "Film perforation stabilizer for analog scan sequences",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.fabriccio.perforation-stabilizer",
    "productName": "Perforation Stabilizer",
    "directories": {
      "output": "../dist"
    },
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "../dist-py/stabilizer_arm64",
        "to": "stabilizer_arm64"
      },
      {
        "from": "../dist-py/stabilizer_x64",
        "to": "stabilizer_x64"
      }
    ]
  }
}
